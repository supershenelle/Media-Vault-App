<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.createProfileController">
   <children>
      <TextField fx:id="usernameField" layoutX="14.0" layoutY="84.0" />
      <Label alignment="CENTER" layoutY="5.0" prefHeight="17.0" prefWidth="600.0" text="Create Profile">
         <font>
            <Font size="25.0" />
         </font>
      </Label>
      <Label layoutX="14.0" layoutY="58.0" prefHeight="17.0" prefWidth="149.0" text="Username">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <Label layoutX="14.0" layoutY="148.0" prefHeight="17.0" prefWidth="149.0" text="Display Name">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <TextField fx:id="displayNameField" layoutX="14.0" layoutY="178.0" />
      <TextArea fx:id="bioField" layoutX="301.0" layoutY="105.0" prefHeight="115.0" prefWidth="283.0" />
      <Label layoutX="301.0" layoutY="69.0" prefHeight="30.0" prefWidth="187.0" text="Bio">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <Button fx:id="confirmButton" layoutX="252.0" layoutY="285.0" mnemonicParsing="false" onAction="#handleConfirm" text="Confirm">
         <font>
            <Font size="20.0" />
         </font>
      </Button>
      <Label fx:id="errorLabel" layoutX="102.0" layoutY="256.0" prefHeight="17.0" prefWidth="397.0">
         <font>
            <Font size="15.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
