<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.updateDiscographyController">
   <children>
      <ListView fx:id="artistListView" layoutX="14.0" layoutY="100.0" onMouseClicked="#handleArtistSelection" prefHeight="200.0" prefWidth="200.0" />
      <ListView fx:id="albumListView" layoutX="241.0" layoutY="100.0" prefHeight="200.0" prefWidth="200.0" />
      <Label layoutX="483.0" layoutY="111.0" text="songs listened" />
      <Label layoutX="246.0" layoutY="5.0" text="Update Discography" />
      <TextField fx:id="songsListenedField" layoutX="459.0" layoutY="136.0" prefHeight="25.0" prefWidth="123.0" />
      <Label layoutX="100.0" layoutY="75.0" text="Artist" />
      <Label layoutX="327.0" layoutY="75.0" text="Album" />
      <Label fx:id="errorLabel" layoutX="502.0" layoutY="212.0" text="Label" />
      <Button fx:id="confirmButton" layoutX="457.0" layoutY="252.0" mnemonicParsing="false" onAction="#handleConfirm" text="Confirm" />
      <Button fx:id="cancelButton" layoutX="533.0" layoutY="252.0" mnemonicParsing="false" onAction="#handleCancel" text="Cancel" />
   </children>
</AnchorPane>
