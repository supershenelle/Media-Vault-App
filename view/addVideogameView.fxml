<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.addVideogameController">
   <children>
      <Label alignment="CENTER" layoutX="11.0" layoutY="24.0" prefHeight="38.0" prefWidth="600.0" text="Add Videogame Entry">
         <font>
            <Font size="26.0" />
         </font>
      </Label>
      <Label layoutX="24.0" layoutY="62.0" text="Videogame Title" />
      <Label layoutX="27.0" layoutY="121.0" text="Developer" />
      <Label layoutX="23.0" layoutY="180.0" text="Year  Released" />
      <Label layoutX="409.0" layoutY="62.0" text="Description" />
      <TextField fx:id="titleField" layoutX="20.0" layoutY="89.0" />
      <TextField fx:id="developerField" layoutX="20.0" layoutY="146.0" />
      <TextField fx:id="yearField" layoutX="20.0" layoutY="200.0" />
      <TextArea fx:id="descriptionField" layoutX="339.0" layoutY="87.0" prefHeight="167.0" prefWidth="200.0" />
      <Button fx:id="confirmButton" layoutX="282.0" layoutY="343.0" mnemonicParsing="false" onAction="#handleConfirm" text="Confirm" />
      <Label layoutX="51.0" layoutY="293.0" text="Status" />
      <RadioButton fx:id="planningRadio" layoutX="19.0" layoutY="319.0" mnemonicParsing="false" text="Planning">
         <font>
            <Font size="15.0" />
         </font>
         <toggleGroup>
            <ToggleGroup fx:id="statusGroup" />
         </toggleGroup>
      </RadioButton>
      <RadioButton fx:id="inProgressRadio" layoutX="17.0" layoutY="345.0" mnemonicParsing="false" text="In Progress">
         <toggleGroup>
            <ToggleGroup fx:id="statusGroup" />
         </toggleGroup>
         <font>
            <Font size="15.0" />
         </font>
      </RadioButton>
      <Label fx:id="errorLabel" layoutX="164.0" layoutY="302.0" prefHeight="17.0" prefWidth="293.0" />
      <Label layoutX="19.0" layoutY="236.0" text="Hours Played" />
      <TextField fx:id="hoursField" layoutX="20.0" layoutY="254.0" />
   </children>
</AnchorPane>
