<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.addMovieController">
   <children>
      <Label alignment="CENTER" layoutX="1.0" layoutY="14.0" prefHeight="38.0" prefWidth="600.0" text="Add Film Entry">
         <font>
            <Font size="26.0" />
         </font>
      </Label>
      <Label layoutX="14.0" layoutY="52.0" text="Film Title" />
      <Label layoutX="17.0" layoutY="111.0" text="Director" />
      <Label layoutX="13.0" layoutY="170.0" text="Year  Released" />
      <Label layoutX="399.0" layoutY="52.0" text="Description" />
      <TextField fx:id="titleField" layoutX="10.0" layoutY="79.0" />
      <TextField fx:id="directorField" layoutX="10.0" layoutY="136.0" />
      <TextField fx:id="yearField" layoutX="10.0" layoutY="200.0" />
      <TextArea fx:id="descriptionField" layoutX="329.0" layoutY="77.0" prefHeight="167.0" prefWidth="200.0" />
      <Button fx:id="confirmButton" layoutX="272.0" layoutY="333.0" mnemonicParsing="false" text="Confirm" />
      <Label layoutX="14.0" layoutY="245.0" text="Status" />
      <RadioButton fx:id="planningRadio" layoutX="18.0" layoutY="271.0" mnemonicParsing="false" text="Planning">
         <font>
            <Font size="15.0" />
         </font>
         <toggleGroup>
            <ToggleGroup fx:id="statusGroup" />
         </toggleGroup>
      </RadioButton>
      <RadioButton fx:id="inProgressRadio" layoutX="18.0" layoutY="311.0" mnemonicParsing="false" text="In Progress" toggleGroup="$statusGroup">
         <font>
            <Font size="15.0" />
         </font>
      </RadioButton>
      <Label fx:id="errorLabel" layoutX="154.0" layoutY="292.0" prefHeight="17.0" prefWidth="293.0" />
   </children>
</AnchorPane>
